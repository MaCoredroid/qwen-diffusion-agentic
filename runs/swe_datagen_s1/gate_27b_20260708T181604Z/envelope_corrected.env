# =============================================================================
# STAGED corrected sampling envelope for the Qwen3.6-27B datagen teacher.
# NOT APPLIED. Drop-in replacement for the LUMO_PROXY_FORCE_* block in
# datagen_gen.sh lines 47-51. Produced by the gate-2 config audit (CONFIG_DELTAS.md).
#
# WHY: the current block (temp 0.6 / top_p 0.95 / top_k 20, enable_thinking=False
# forced in the proxy) was inherited from the NON-thinking Qwen3.5-9B AR teacher.
# It is a mode/sampler chimera for the 27B (a thinking model). Pick ONE regime.
# =============================================================================

# ---- REGIME T: thinking ON — officially-tuned agentic path (RECOMMENDED) -----
# == ckpt generation_config.json defaults == Qwen3.6 thinking-general sampling.
# Requires: (a) proxy enable_thinking made env-gated & set True (see CONFIG_DELTAS
# delta D6 — 1-line proxy change), (b) proxy --max-tokens raised (thinking needs
# headroom; DEFAULT_PROXY_MAX_TOKENS 2048 -> >=8192), (c) preserve <think> across
# turns (codex template already does).
export LUMO_PROXY_FORCE_TEMPERATURE="${LUMO_PROXY_FORCE_TEMPERATURE:-1.0}"
export LUMO_PROXY_FORCE_TOP_P="${LUMO_PROXY_FORCE_TOP_P:-0.95}"
export LUMO_PROXY_FORCE_TOP_K="${LUMO_PROXY_FORCE_TOP_K:-20}"
export LUMO_PROXY_FORCE_MIN_P="${LUMO_PROXY_FORCE_MIN_P:-0.0}"
export LUMO_PROXY_FORCE_PRESENCE_PENALTY="${LUMO_PROXY_FORCE_PRESENCE_PENALTY:-0.0}"
export LUMO_PROXY_FORCE_SEED="${LUMO_PROXY_FORCE_SEED:-1234}"
export LUMO_ENABLE_THINKING="${LUMO_ENABLE_THINKING:-true}"

# ---- REGIME I: thinking OFF — lower cost/latency (Qwen3.6 non-thinking/instruct)
# Uncomment to use instead of Regime T. This is the CURRENT mode but with the
# CORRECT non-thinking sampler (current 0.6/0.95/20 is wrong for non-thinking).
# export LUMO_PROXY_FORCE_TEMPERATURE="0.7"
# export LUMO_PROXY_FORCE_TOP_P="0.80"
# export LUMO_PROXY_FORCE_TOP_K="20"
# export LUMO_PROXY_FORCE_MIN_P="0.0"
# export LUMO_PROXY_FORCE_PRESENCE_PENALTY="1.5"
# export LUMO_PROXY_FORCE_SEED="1234"
# export LUMO_ENABLE_THINKING="false"

# ---- Pure ARGUMENT-EXACTNESS battery only (NOT for agentic rollouts) ----------
# NVIDIA's NVFP4 tool-use bench (tau2) used GREEDY; legal ONLY non-thinking.
# For a verbatim-copy gate you may instead pin: temp 0.0 / top_p 1.0, thinking OFF.
