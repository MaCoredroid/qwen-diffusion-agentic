+### MARK - infra hardening (2026-07-09): bounded, cached, retrying raw-file fetch.
+# The env/requirements paths below fetch immutable files from raw.githubusercontent.com.
+# Upstream used a bare requests.get() with NO timeout: a single flaky read could hang
+# unbounded and, when it finally raised ReadTimeout, propagate out of make_test_spec and
+# KILL an entire scoring run (zeroing a whole 50-instance report). We wrap the fetch with
+# an explicit (connect, read) timeout, a few backoff retries, and an on-disk cache (files
+# AT a commit never change, so caching is exact and cuts future net exposure to ~zero).
+# On network failure that survives all retries we raise EnvFetchError, which callers catch
+# per-instance to skip just that instance instead of aborting the whole run.
+RAW_FETCH_TIMEOUT = float(os.environ.get("SWE_RAW_FETCH_TIMEOUT", "30"))  # (connect, read) s
+RAW_FETCH_RETRIES = int(os.environ.get("SWE_RAW_FETCH_RETRIES", "3"))     # attempts AFTER the first
+RAW_FETCH_CACHE_DIR = Path(
+    os.environ.get(
+        "SWE_RAW_FETCH_CACHE",
+        # default: <fork-root>/.raw_fetch_cache  (utils.py is .../swebench/harness/)
+        str(Path(__file__).resolve().parents[2] / ".raw_fetch_cache"),
+    )
+)
+
+RawFetchResult = namedtuple("RawFetchResult", ["status_code", "text"])
+
+
+class EnvFetchError(Exception):
+    """A raw env/requirements file could not be fetched after retries (network fault).
+
+    Raised in place of a bare requests exception so callers can skip the affected
+    instance gracefully rather than aborting the whole evaluation run.
+    """
+
+
+def _raw_cache_path(url: str) -> Path:
+    # Key on the full raw URL (== repo + commit + path); immutable at a commit.
+    digest = hashlib.sha256(url.encode("utf-8")).hexdigest()
+    return RAW_FETCH_CACHE_DIR / digest
+
+
+def fetch_raw_file(url: str) -> RawFetchResult:
+    """Fetch a raw.githubusercontent.com file with timeout, retries, and on-disk cache.
+
+    Returns RawFetchResult(status_code, text). A non-200 (e.g. 404) is returned as-is so
+    the caller's path-probing loop keeps its original semantics (try the next path). Only
+    a *network* failure that survives all retries raises EnvFetchError.
+    """
+    cache_path = _raw_cache_path(url)
+    if cache_path.is_file():
+        try:
+            return RawFetchResult(200, cache_path.read_text())
+        except OSError:
+            pass  # unreadable cache entry -> fall through and refetch
+
+    last_exc = None
+    for attempt in range(RAW_FETCH_RETRIES + 1):
+        try:
+            resp = requests.get(url, timeout=(RAW_FETCH_TIMEOUT, RAW_FETCH_TIMEOUT))
+        except requests.RequestException as e:
+            # Only transient network faults (timeouts, connection resets) land here; a
+            # 404 is a normal completed response and is NOT retried below.
+            last_exc = e
+            if attempt < RAW_FETCH_RETRIES:
+                time.sleep(min(2 ** attempt, 8))  # backoff: 1s, 2s, 4s, ...
+                continue
+            raise EnvFetchError(
+                f"network failure fetching {url} after {RAW_FETCH_RETRIES + 1} attempt(s): {e}"
+            ) from e
+        if resp.status_code == 200:
+            # Cache the immutable body atomically (best-effort; cache is a pure optimization).
+            try:
+                RAW_FETCH_CACHE_DIR.mkdir(parents=True, exist_ok=True)
+                tmp = cache_path.with_name(cache_path.name + f".tmp.{os.getpid()}")
+                tmp.write_text(resp.text)
+                os.replace(tmp, cache_path)  # atomic on same filesystem
+            except OSError:
+                pass
+        return RawFetchResult(resp.status_code, resp.text)
+    # Unreachable (loop either returns or raises), but keeps the type checker honest.
+    raise EnvFetchError(f"network failure fetching {url}: {last_exc}")
+
+
