+def safe_make_test_specs(instances: list[SWEbenchInstance]) -> list[TestSpec]:
+    """Map make_test_spec over instances, skipping (not aborting) instances whose env or
+    requirements file could not be fetched from raw.githubusercontent.com after retries.
+
+    make_test_spec eagerly fetches each instance's env/requirements over the network. A
+    single transient fetch fault used to propagate out and KILL the whole run (zeroing a
+    50-instance report). Here we isolate that fault to the one instance: it is logged and
+    dropped, so its image is never built and it later surfaces as an unevaluated/error id
+    in the report, while every other instance proceeds. EnvFetchError only -- real bugs
+    (KeyError, missing version specs, ...) still raise so they stay visible.
+    """
+    specs: list[TestSpec] = []
+    for instance in instances:
+        try:
+            specs.append(make_test_spec(instance))
+        except EnvFetchError as e:
+            iid = instance.get(KEY_INSTANCE_ID, "?") if isinstance(instance, dict) \
+                else getattr(instance, "instance_id", "?")
+            print(f"[swebench] SKIP {iid}: env/requirements fetch failed after retries "
+                  f"-> instance dropped from this run (not fatal): {e}")
+    return specs
+
+
