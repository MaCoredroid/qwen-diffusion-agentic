diff --git a/tests/test_raw_fetch_hardening.py b/tests/test_raw_fetch_hardening.py
new file mode 100644
index 0000000..48cb824
--- /dev/null
+++ b/tests/test_raw_fetch_hardening.py
@@ -0,0 +1,144 @@
+"""Unit-smoke for the hardened raw-file fetch wrapper (localhost only, no external net).
+
+Exercises the exact defect class (unbounded read -> whole-run kill) and every branch of
+the fix: on-disk cache, 404 path-probe passthrough, bounded read-timeout -> retries ->
+EnvFetchError, connection-refused -> EnvFetchError, and per-instance graceful skip.
+Run with the fork venv:  .venv-swegym/bin/python smoke_fetch_raw.py
+"""
+import sys, socket, time, threading, tempfile, shutil
+from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
+from pathlib import Path
+
+import swebench.harness.utils as u
+import swebench.harness.test_spec as ts
+
+HITS = {"ok": 0, "missing": 0, "slow": 0}
+
+
+class H(BaseHTTPRequestHandler):
+    def log_message(self, *a):  # silence access log
+        pass
+
+    def do_GET(self):
+        if self.path.startswith("/ok"):
+            HITS["ok"] += 1
+            body = b"OK-BODY\n"
+            self.send_response(200); self.send_header("Content-Length", str(len(body)))
+            self.end_headers(); self.wfile.write(body)
+        elif self.path.startswith("/missing"):
+            HITS["missing"] += 1
+            self.send_response(404); self.end_headers(); self.wfile.write(b"nope")
+        elif self.path.startswith("/slow"):
+            HITS["slow"] += 1
+            time.sleep(3)  # longer than the 1s read timeout -> client bails first
+            try:
+                self.send_response(200); self.end_headers(); self.wfile.write(b"late")
+            except (BrokenPipeError, ConnectionError):
+                pass  # client already closed after read timeout (expected)
+        else:
+            self.send_response(500); self.end_headers()
+
+
+def free_port():
+    s = socket.socket(); s.bind(("127.0.0.1", 0)); p = s.getsockname()[1]; s.close()
+    return p  # momentarily closed -> connect() gets ECONNREFUSED
+
+
+def main():
+    fails = []
+
+    def check(name, cond, extra=""):
+        print(("PASS " if cond else "FAIL ") + name + ((" :: " + extra) if extra else ""))
+        if not cond:
+            fails.append(name)
+
+    srv = ThreadingHTTPServer(("127.0.0.1", 0), H)  # threaded so a slow handler can't block retries
+    port = srv.server_address[1]
+    threading.Thread(target=srv.serve_forever, daemon=True).start()
+    base = f"http://127.0.0.1:{port}"
+
+    cache = Path(tempfile.mkdtemp(prefix="rawcache_"))
+    u.RAW_FETCH_CACHE_DIR = cache
+    u.RAW_FETCH_RETRIES = 1          # keep the smoke fast (2 attempts total)
+    u.RAW_FETCH_TIMEOUT = 1.0        # 1s read timeout (backoff between attempts is real but short)
+
+    # 1) 200 -> body + on-disk cache written, exactly one network hit
+    r = u.fetch_raw_file(base + "/ok/a")
+    check("200-body", r.status_code == 200 and r.text == "OK-BODY\n", r.text.strip())
+    check("cache-written", len(list(cache.iterdir())) == 1)
+    check("net-hit-once", HITS["ok"] == 1, f"hits={HITS['ok']}")
+
+    # 2) cache HIT bypasses the network entirely: make requests.get explode, yet the
+    #    already-cached URL still resolves from disk (future net exposure ~0).
+    orig_get = u.requests.get
+    u.requests.get = lambda *a, **k: (_ for _ in ()).throw(AssertionError("network called on cache hit"))
+    try:
+        r2 = u.fetch_raw_file(base + "/ok/a")
+        check("cache-hit-no-network", r2.status_code == 200 and r2.text == "OK-BODY\n")
+    except AssertionError as e:
+        check("cache-hit-no-network", False, str(e))
+    finally:
+        u.requests.get = orig_get
+    check("no-extra-net-hit", HITS["ok"] == 1, f"hits={HITS['ok']}")
+
+    # 3) 404 -> returned as-is, NOT retried, NOT an exception (path-probe semantics intact)
+    HITS["missing"] = 0
+    r3 = u.fetch_raw_file(base + "/missing/x")
+    check("404-passthrough", r3.status_code == 404)
+    check("404-not-retried", HITS["missing"] == 1, f"hits={HITS['missing']}")
+
+    # 4) bounded READ TIMEOUT (the exact bug class) -> retries -> EnvFetchError, no hang
+    HITS["slow"] = 0
+    t0 = time.time()
+    raised = None
+    try:
+        u.fetch_raw_file(base + "/slow/y")
+    except u.EnvFetchError as e:
+        raised = e
+    dt = time.time() - t0
+    check("readtimeout-raises-EnvFetchError", isinstance(raised, u.EnvFetchError), str(raised))
+    check("readtimeout-retried", HITS["slow"] == u.RAW_FETCH_RETRIES + 1, f"attempts={HITS['slow']}")
+    check("readtimeout-bounded", dt < 10, f"{dt:.1f}s")  # ~2x1s, nowhere near unbounded
+
+    # 5) connection refused (closed port) -> EnvFetchError after retries
+    dead = f"http://127.0.0.1:{free_port()}/ok/never"
+    try:
+        u.fetch_raw_file(dead); connfail = False
+    except u.EnvFetchError:
+        connfail = True
+    check("connrefused-raises-EnvFetchError", connfail)
+
+    srv.shutdown(); srv.server_close()
+
+    # 6) safe_make_test_specs: one instance's fetch fails -> it is skipped, others survive,
+    #    and NO exception escapes (one flaky fetch never zeros the batch).
+    orig_mts = ts.make_test_spec
+    def fake_mts(inst):
+        if inst["instance_id"] == "bad__1":
+            raise u.EnvFetchError("simulated network fault")
+        return f"spec::{inst['instance_id']}"
+    ts.make_test_spec = fake_mts
+    try:
+        specs = ts.safe_make_test_specs([
+            {"instance_id": "good__1"}, {"instance_id": "bad__1"}, {"instance_id": "good__2"}])
+        check("skip-keeps-good", specs == ["spec::good__1", "spec::good__2"], str(specs))
+        check("skip-drops-bad", "spec::bad__1" not in specs)
+    finally:
+        ts.make_test_spec = orig_mts
+
+    shutil.rmtree(cache, ignore_errors=True)
+    if fails:
+        print("\nFAILURES:", fails)
+    else:
+        print("\nALL SMOKE CHECKS PASSED")
+    return fails
+
+
+def test_raw_fetch_hardening():
+    """pytest entrypoint: no external network, no docker (localhost stub server only)."""
+    fails = main()
+    assert not fails, f"raw-fetch hardening smoke failures: {fails}"
+
+
+if __name__ == "__main__":
+    sys.exit(1 if main() else 0)
